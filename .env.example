# Copy to .env and fill in values (never commit .env).
TG_BOT_TOKEN=your_bot_token_from_botfather

# Comma-separated Telegram user IDs granted /admin on startup
INITIAL_ADMIN_IDS=123456789

# Optional legacy token aliases still supported
# TELEGRAM_BOT_TOKEN=
# BOT_TOKEN=

# Optional: directory for quiz_bot.db (use /data in Docker)
# QUIZ_BOT_DATA_DIR=

# Optional: path to a specific env file
# DOTENV_PATH=

# Optional: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# Optional: en, ru, uz
# DEFAULT_LANGUAGE=en

# Optional SQLite busy timeout for concurrent writes
# DB_BUSY_TIMEOUT_MS=5000

# Optional Telegram HTTP timeouts
# TG_CONNECT_TIMEOUT=10
# TG_READ_TIMEOUT=30
# TG_WRITE_TIMEOUT=30
# TG_POOL_TIMEOUT=10
